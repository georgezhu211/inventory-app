<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Pokemon</title>
  </head>
  <body>
    <h1>Edit Pokemon</h1>
    <%- include("../partials/errors.ejs") %>
    <form action="/pokemon/<%= pokemon.id %>/update" method="POST">
      <label for="name">Pokemon: </label>
      <input type="text" name="name" id="name" value="<%= pokemon.name %>" />

      <label for="type">Choose a type: </label>
      <select name="type_id" id="type">
        <% for (const type of types) { %>
          <option value="<%= type.id %>" <%= type.id === pokemon.type_id ? 'selected' : '' %>>
            <%= type.name %>
          </option>
        <% } %>
      </select>
      <button type="submit">Submit</button>
    </form>
    <a href="/pokemon">Return</a>
  </body>
</html>
