<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Types</title>
  </head>
  <body>
    <a href="/">Back to home</a>
    <h1>Type List</h1>
    <ul>
      <% types.forEach(type => { %>
      <li>
        ID: <%= type.id %>, Name: <%= type.name %>
        <a href="/types/<%= type.id %>">View</a>
        <a href="/types/<%= type.id %>/edit">Edit</a>
        <form
          action="/types/<%= type.id %>/delete"
          method="POST"
          style="display: inline"
        >
          <button
            type="submit"
            onclick="return confirm('Are you sure you want to delete this Type?');"
          >
            Delete
          </button>
        </form>
      </li>

      <% }); %>
    </ul>
    <a href="/types/new">Add Type</a>
  </body>
</html>
